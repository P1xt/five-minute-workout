    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@angular/service-worker": "20.3.25",
    "idb": "^8.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.30",
    "@angular/cli": "20.3.30",
    "@angular/compiler-cli": "20.3.25",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.30",
    "angular-cli-ghpages": "^3.1.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "~5.8.3",
