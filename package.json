{
  "name": "five-minute-workout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "deploy": "ng deploy --base-href=\"https://p1xt.github.io/five-minute-workout/\"",
    "preview:pwa": "ng build && npx http-server dist/five-minute-workout/browser -p 4200"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
